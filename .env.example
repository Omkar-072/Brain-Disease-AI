# Brain Disease AI - Environment Configuration
# Copy this file to .env and fill in your values

# Application Settings
APP_NAME="Brain Disease AI"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Configuration
DATABASE_URL=sqlite:///./brain_disease.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost:5432/brain_disease_db

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@braindisease.ai
EMAILS_FROM_NAME="Brain Disease AI"

# File Upload Settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.dcm,.nii

# AI Model Settings
MODEL_PATH=app/ai_models/weights
CONFIDENCE_THRESHOLD=0.7

# Security
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
